generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  email           String?          @unique
  phone           String?          @unique
  passwordHash    String?
  name            String
  image           String?
  role            Role             @default(CUSTOMER)
  providerProfile ProviderProfile?
  bookings        Booking[]        @relation("CustomerBookings")
  reviews         Review[]
  messagesSent    Message[]        @relation("MessageSender")
  messagesRecv    Message[]        @relation("MessageReceiver")
  otpCodes        PhoneOtp[]
  accounts        Account[]
  sessions        Session[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([role])
  @@index([name])
}

model ProviderProfile {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @unique @db.ObjectId
  user           User           @relation(fields: [userId], references: [id])
  status         ProviderStatus @default(PENDING)
  bio            String?
  division       String
  district       String
  area           String
  latitude       Float?
  longitude      Float?
  verified       Boolean        @default(false)
  hourlyRate     Float?
  totalEarnings  Float          @default(0)
  services       Service[]
  bookings       Booking[]      @relation("ProviderBookings")
  receivedReview Review[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([division, district, area])
  @@index([status])
}

model Category {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String      @unique
  parentId      String?     @db.ObjectId
  parent        Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children      Category[]  @relation("CategoryTree")
  serviceTypes  Service[]
  createdAt     DateTime    @default(now())

  @@index([parentId])
  @@index([name])
}

model Service {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String      @unique
  description   String
  priceFrom     Float
  priceTo       Float?
  categoryId    String      @db.ObjectId
  category      Category    @relation(fields: [categoryId], references: [id])
  providerId    String      @db.ObjectId
  provider      ProviderProfile @relation(fields: [providerId], references: [id])
  images        String[]
  tags          String[]
  division      String
  district      String
  area          String
  isActive      Boolean     @default(true)
  bookings      Booking[]
  reviews       Review[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([categoryId])
  @@index([providerId])
  @@index([division, district, area])
  @@index([title])
}

model Booking {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  customerId    String        @db.ObjectId
  customer      User          @relation("CustomerBookings", fields: [customerId], references: [id])
  providerId    String        @db.ObjectId
  provider      ProviderProfile @relation("ProviderBookings", fields: [providerId], references: [id])
  serviceId     String        @db.ObjectId
  service       Service       @relation(fields: [serviceId], references: [id])
  problemText   String
  scheduledAt   DateTime
  status        BookingStatus @default(PENDING)
  locationNote  String?
  quotedPrice   Float?
  review        Review?
  messages      Message[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([scheduledAt])
}

model Review {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  bookingId     String          @unique @db.ObjectId
  booking       Booking         @relation(fields: [bookingId], references: [id])
  customerId    String          @db.ObjectId
  customer      User            @relation(fields: [customerId], references: [id])
  providerId    String          @db.ObjectId
  provider      ProviderProfile @relation(fields: [providerId], references: [id])
  serviceId     String          @db.ObjectId
  service       Service         @relation(fields: [serviceId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime        @default(now())

  @@index([providerId])
  @@index([serviceId])
}

model Message {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  bookingId     String?   @db.ObjectId
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  fromUserId    String    @db.ObjectId
  fromUser      User      @relation("MessageSender", fields: [fromUserId], references: [id])
  toUserId      String    @db.ObjectId
  toUser        User      @relation("MessageReceiver", fields: [toUserId], references: [id])
  content       String
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([bookingId])
  @@index([fromUserId, toUserId])
}

model PhoneOtp {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?   @db.ObjectId
  user          User?     @relation(fields: [userId], references: [id])
  phone         String
  code          String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
